# Resend — create a free account at resend.com, then get your API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for outbound emails (must be on a verified domain in Resend)
# While testing you can leave this blank — Resend will use onboarding@resend.dev
FROM_EMAIL=hello@pronailsseattle.com

# Where contact form messages are delivered (usually the client's business email)
CONTACT_EMAIL=hello@pronailsseattle.com

# GoCheckIn — provided by the client
GOCHECKIN_API_KEY=
GOCHECKIN_LOCATION_ID=
# Service IDs are per-service; add them once you have the full list from the client
# GOCHECKIN_SERVICE_ID_CLASSIC_MANI=
# GOCHECKIN_SERVICE_ID_GEL_MANI=
# etc.
